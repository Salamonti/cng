[#] /etc/systemd/system/ragapi.service
[Unit]
Description=RAG Query API (uvicorn)
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/USER/TheBeast/RAG
ExecStart=/home/USER/TheBeast/RAG/.venv/bin/uvicorn query_api:app --host 0.0.0.0 --port 8007
Restart=always
User=USER
Group=USER

[Install]
WantedBy=multi-user.target

